parameters:
    errorFormat: symplify

    paths:
        - bin
        - src
        - tests
        - views

    excludePaths:
        - */Fixture/*

    level: 8

    treatPhpDocTypesAsCertain: false

    # @see https://github.com/symplify/phpstan-rules
    symfonyReturnType: true
    laravelReturnType: true
    pathStrings: true
